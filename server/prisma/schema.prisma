generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  login    String
  campus   String
  isAdmin  Boolean @default(false)
  spotifyId String?
  spotifyToken    String? 
}